{
  "name": "containless",
  "version": "0.2.0",
  "description": "Docker-like CLI for runtime environments — install and run Node.js, Python, Java, and Go locally inside your project folder, completely isolated from global installs.",
  "main": "./dist/cli.js",
  "bin": {
    "containless": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build",
    "lint": "tsc --noEmit"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "cli",
    "runtime",
    "docker",
    "container",
    "node",
    "python",
    "java",
    "go",
    "environment",
    "isolated",
    "local",
    "version-manager"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AngheloDeArroz/Containless.git"
  },
  "homepage": "https://github.com/AngheloDeArroz/Containless#readme",
  "bugs": {
    "url": "https://github.com/AngheloDeArroz/Containless/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "tar": "^7.4.0",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.0",
    "@types/unzipper": "^0.10.10",
    "rimraf": "^5.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
