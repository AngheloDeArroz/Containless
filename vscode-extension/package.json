{
  "name": "containless",
  "displayName": "Containless",
  "description": "Run projects instantly without installing system dependencies or learning Docker. Automatically provision isolated, project-local runtimes for Node.js, Python, Java, and Go.",
  "version": "0.1.0",
  "publisher": "containless",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/AngheloDeArroz/Containless"
  },
  "homepage": "https://github.com/AngheloDeArroz/Containless#readme",
  "bugs": {
    "url": "https://github.com/AngheloDeArroz/Containless/issues"
  },
  "galleryBanner": {
    "color": "#0F172A",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "runtime",
    "sandbox",
    "python",
    "node",
    "java",
    "go",
    "containless",
    "isolated",
    "environment",
    "container"
  ],
  "activationEvents": [
    "workspaceContains:containless.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "containless.detectRuntimes",
        "title": "Containless: Detect and Configure Runtimes"
      },
      {
        "command": "containless.resetRuntimes",
        "title": "Containless: Reset to Global Runtimes"
      },
      {
        "command": "containless.init",
        "title": "Containless: Initialize Project"
      },
      {
        "command": "containless.run",
        "title": "Containless: Run Project"
      },
      {
        "command": "containless.install",
        "title": "Containless: Install Runtime"
      },
      {
        "command": "containless.clean",
        "title": "Containless: Clean Runtimes"
      },
      {
        "command": "containless.info",
        "title": "Containless: Show Runtime Info"
      },
      {
        "command": "containless.showQuickPick",
        "title": "Containless: Show Commands"
      }
    ],
    "configuration": {
      "title": "Containless",
      "properties": {
        "containless.cliPath": {
          "type": "string",
          "default": "",
          "description": "Override the path to the containless CLI binary. Leave empty to auto-detect."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "lint": "tsc --noEmit",
    "package": "npx @vscode/vsce package",
    "publish": "npx @vscode/vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {}
}
