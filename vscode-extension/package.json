{
  "name": "containless",
  "displayName": "Containless",
  "description": "Sandbox your project runtimes — automatically detect and enforce local Node.js, Python, Java, and Go runtimes installed by Containless, so your editor and terminal never touch global installs.",
  "version": "0.1.0",
  "publisher": "containless",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/AngheloDeArroz/Containless"
  },
  "homepage": "https://github.com/AngheloDeArroz/Containless#readme",
  "bugs": {
    "url": "https://github.com/AngheloDeArroz/Containless/issues"
  },
  "galleryBanner": {
    "color": "#0F172A",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "runtime",
    "sandbox",
    "python",
    "node",
    "java",
    "go",
    "containless",
    "isolated",
    "environment",
    "container"
  ],
  "activationEvents": [
    "workspaceContains:containless.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "containless.detectRuntimes",
        "title": "Containless: Detect and Configure Runtimes"
      },
      {
        "command": "containless.resetRuntimes",
        "title": "Containless: Reset to Global Runtimes"
      }
    ]
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "lint": "tsc --noEmit",
    "package": "npx @vscode/vsce package",
    "publish": "npx @vscode/vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {}
}
